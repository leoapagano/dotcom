---
import background from '../assets/background.png';
import '../styles/reset.css';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Contact | leoapagano.com</title>
	</head>
	<body>
		<div id="container">
			<img id="background" src={background.src} alt="Background image" fetchpriority="high" />
			<main>
				<h1>Contact</h1>
				<p>Stuff goes here.</p>
			</main>
		</div>
	</body>
</html>

<style>
	/* Basics */
	html, body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
	}


	/* Background image */
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		object-fit: cover;
		object-position: top center;
	}


	/* Text */
	h1 {
		font-size: 22px;
		margin-top: 0.25em;
	}
	a {
		display: flex;
		align-items: center;
		padding: 10px 12px;
		color: #111827;
		text-decoration: none;
		transition: color 0.2s;
	}
	a:hover {
		color: rgb(78, 80, 86);
	}
	p {
		color: #4b5563;
		font-size: 16px;
		line-height: 24px;
		letter-spacing: -0.006em;
		margin: 0;
	}
</style>




